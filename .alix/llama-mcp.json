{
  "mcpServers": {
    "web_fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "web_search": {
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"]
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time", "--local-timezone=Africa/Lagos"]
    }
  }
}
