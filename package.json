{
  "name": "alix",
  "version": "0.5.0",
  "description": "Agentic Lifecycle & Intelligence eXchange",
  "author": "Babasola Oduga",
  "license": "MIT",
  "repository": "github:boduga/ALiX",
  "homepage": "https://github.com/boduga/ALiX",
  "keywords": [
    "ai",
    "agent",
    "coding",
    "cli",
    "llm",
    "claude",
    "openai"
  ],
  "type": "module",
  "workspaces": [
    "packages/tool-repair"
  ],
  "bin": {
    "alix": "./bin/alix.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "copy:profiles": "node scripts/copy-build-artifacts.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json && node scripts/copy-build-artifacts.mjs",
    "test": "pnpm test:node && pnpm test:vitest",
    "test:node": "node --test --test-timeout=30000 dist/tests/*.test.js dist/tests/**/*.test.js",
    "test:unit:node": "echo \"[legacy] node:test suite removed from CI — use pnpm test:vitest\"",
    "test:integration": "node --test --test-concurrency=1 dist/tests/integration/*.test.js",
    "test:vitest": "vitest run --config vitest.config.mts",
    "test:manual": "node --test --test-concurrency=1 dist/tests/manual/suite-*.test.js",
    "test:coverage": "c8 node --test dist/tests/*.test.js dist/tests/**/*.test.js && c8 vitest run tests/autonomy/scope-tracker.vitest.ts tests/memory/user-preference-store.vitest.ts --config vitest.config.mts",
    "coverage:report": "c8 report --reporter=text-summary",
    "verify:deps": "node scripts/verify-deps.mjs",
    "check": "pnpm build && pnpm test:node && pnpm verify:deps",
    "test:ci": "pnpm test:node:ci && pnpm test:vitest",
    "test:node:ci": "find dist/tests -name '*.test.js' ! -path 'dist/tests/manual/*' ! -path 'dist/tests/pty/*' ! -path 'dist/tests/soak/*' ! -path 'dist/tests/integration/*' ! -path 'dist/tests/cli/commands/skills/*' ! -path 'dist/tests/tests/*' -print0 | xargs -0 node --test --test-timeout=30000",
    "test:manual:tui": "node --test --test-concurrency=1 dist/tests/manual/suite-p-tui-smoke.test.js",
    "test:pty:tui": "ALIX_PTY_TESTS=1 node --test --test-concurrency=1 dist/tests/pty/tui-pty.test.js",
    "test:soak:quick": "node --test --test-concurrency=1 dist/tests/soak/corruption-recovery.test.js dist/tests/soak/store-load.test.js dist/tests/soak/memory-growth.test.js dist/tests/soak/daemon-resource-soak.test.js",
    "test:soak": "ALIX_SOAK_TESTS=1 node --test --test-concurrency=1 dist/tests/soak/*.test.js",
    "test:soak:ci": "ALIX_SOAK_LEVEL=ci node --test --test-concurrency=1 dist/tests/soak/adaptation-*.soak.test.js",
    "test:soak:bench": "ALIX_SOAK_LEVEL=bench node --test --test-concurrency=1 dist/tests/soak/adaptation-*.soak.test.js",
    "test:soak:adaptation": "node --test --test-concurrency=1 dist/tests/soak/adaptation-*.soak.test.js",
    "test:stress": "node --test --test-timeout=60000 dist/tests/stress/*.test.js",
    "test:skips:audit": "bash scripts/test-skips-audit.sh",
    "check:package-manager": "bash scripts/check-package-manager.sh",
    "fresh": "pnpm build && node dist/src/cli.js doctor"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "c8": "11.0.0",
    "glob": "13.0.6",
    "minimatch": "10.2.5",
    "typescript": "7.0.2",
    "undici-types": "8.5.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@xenova/transformers": "2.17.2",
    "better-sqlite3": "12.11.1",
    "cli-spinners": "3.4.0",
    "effect": "3.21.4",
    "neo-blessed": "0.2.0",
    "tiktoken": "1.0.22",
    "yaml": "2.9.0"
  }
}
