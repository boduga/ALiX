{
  "name": "alix",
  "version": "0.3.0-rc.2",
  "description": "Agentic Lifecycle & Intelligence eXchange",
  "author": "Babasola Oduga",
  "license": "MIT",
  "repository": "github:boduga/ALiX",
  "homepage": "https://github.com/boduga/ALiX",
  "keywords": [
    "ai",
    "agent",
    "coding",
    "cli",
    "llm",
    "claude",
    "openai"
  ],
  "type": "module",
  "workspaces": [
    "packages/tool-repair"
  ],
  "bin": {
    "alix": "./bin/alix.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "copy:profiles": "mkdir -p dist/src/config/profiles && cp src/config/profiles/*.json dist/src/config/profiles/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json && npm run copy:profiles && mkdir -p dist/src/ui dist/src/db/migrations && cp src/ui/index.html src/ui/app.js src/ui/projection.js src/ui/styles.css dist/src/ui/ && cp src/db/migrations/0001_m09_kernel.sql dist/src/db/migrations/",
    "test": "npm run test:node && npm run test:vitest",
    "test:node": "node --test --test-timeout=30000 dist/tests/*.test.js dist/tests/**/*.test.js",
    "test:unit:node": "find dist/tests -name '*.test.js' ! -path 'dist/tests/manual/*' ! -path 'dist/tests/pty/*' ! -path 'dist/tests/soak/*' ! -path 'dist/tests/integration/*' ! -path 'dist/tests/cli/commands/skills/*' -print0 | xargs -0 node --test --test-timeout=30000",
    "test:integration": "node --test --test-concurrency=1 dist/tests/integration/*.test.js",
    "test:vitest": "npx vitest run tests/autonomy/scope-tracker.vitest.ts tests/memory/user-preference-store.vitest.ts --config vitest.config.mts",
    "test:manual": "node --test --test-concurrency=1 dist/tests/manual/suite-*.test.js",
    "test:coverage": "c8 node --test dist/tests/*.test.js dist/tests/**/*.test.js && c8 npx vitest run tests/autonomy/scope-tracker.vitest.ts tests/memory/user-preference-store.vitest.ts --config vitest.config.mts",
    "coverage:report": "c8 report --reporter=text-summary",
    "verify:deps": "node scripts/verify-deps.mjs",
    "check": "npm run build && npm run test:node && npm run verify:deps",
    "test:ci": "npm run test:node:ci && npm run test:vitest",
    "test:node:ci": "find dist/tests -name '*.test.js' ! -path 'dist/tests/manual/*' ! -path 'dist/tests/pty/*' ! -path 'dist/tests/soak/*' ! -path 'dist/tests/integration/*' ! -path 'dist/tests/cli/commands/skills/*' -print0 | xargs -0 node --test --test-timeout=30000",
    "test:manual:tui": "node --test --test-concurrency=1 dist/tests/manual/suite-p-tui-smoke.test.js",
    "test:pty:tui": "ALIX_PTY_TESTS=1 node --test --test-concurrency=1 dist/tests/pty/tui-pty.test.js",
    "test:soak:quick": "node --test --test-concurrency=1 dist/tests/soak/corruption-recovery.test.js dist/tests/soak/store-load.test.js dist/tests/soak/memory-growth.test.js",
    "test:soak": "ALIX_SOAK_TESTS=1 node --test --test-concurrency=1 dist/tests/soak/*.test.js",
    "fresh": "npm run build && node dist/src/cli.js doctor"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.0.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "c8": "11.0.0",
    "minimatch": "10.2.5",
    "node-pty": "1.1.0-beta34",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "dependencies": {
    "@xenova/transformers": "2.17.2",
    "better-sqlite3": "12.10.0",
    "cli-spinners": "3.4.0",
    "ink": "7.0.5",
    "ink-text-input": "6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tiktoken": "1.0.22",
    "tree-sitter": "0.21.1",
    "tree-sitter-typescript": "0.23.2",
    "yaml": "2.9.0"
  }
}
