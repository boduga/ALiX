{
  "mcpServers": [
    {
      "name": "custom-api",
      "type": "http",
      "url": "https://api.example.com/mcp",
      "headers": {
        "Authorization": "Bearer sk-secret-token-12345",
        "X-API-Key": "abc123def456"
      }
    },
    {
      "name": "database-mcp",
      "type": "stdio",
      "command": "npx",
      "args": ["@org/db-mcp"],
      "env": {
        "DB_PASSWORD": "s3cr3t!",
        "DB_API_KEY": "db-key-98765",
        "DATABASE_URL": "postgresql://user:pass@localhost:5432/mydb"
      }
    },
    {
      "name": "observability",
      "type": "websocket",
      "url": "wss://obs.example.com/mcp",
      "headers": {
        "Authorization": "Bearer obs-token-abc"
      }
    }
  ]
}
