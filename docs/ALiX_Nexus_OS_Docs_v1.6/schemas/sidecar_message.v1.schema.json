{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SidecarMessage",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "type",
        "sidecar",
        "version",
        "schemaVersion",
        "operations",
        "capabilities",
        "supportsCancellation"
      ],
      "properties": {
        "type": {
          "const": "hello"
        },
        "sidecar": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supportsCancellation": {
          "type": "boolean"
        },
        "maxInputBytes": {
          "type": "integer"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "id",
        "schemaVersion",
        "sidecar",
        "operation",
        "input",
        "policyDecisionId",
        "timeoutMs"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "schemaVersion": {
          "const": "1.0"
        },
        "sidecar": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "input": {
          "type": "object"
        },
        "policyDecisionId": {
          "type": "string"
        },
        "timeoutMs": {
          "type": "integer"
        }
      }
    }
  ]
}