{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AlixEventEnvelope",
  "type": "object",
  "required": [
    "id",
    "schemaVersion",
    "timestamp",
    "sessionId",
    "actorType",
    "actorId",
    "eventType",
    "payload",
    "visibility"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "timestamp": {
      "type": "string"
    },
    "sessionId": {
      "type": "string"
    },
    "workflowId": {
      "type": "string"
    },
    "graphId": {
      "type": "string"
    },
    "nodeId": {
      "type": "string"
    },
    "actorType": {
      "enum": [
        "user",
        "agent",
        "tool",
        "model",
        "system",
        "sidecar",
        "policy"
      ]
    },
    "actorId": {
      "type": "string"
    },
    "eventType": {
      "type": "string"
    },
    "payload": {},
    "visibility": {
      "enum": [
        "public",
        "internal",
        "sensitive"
      ]
    },
    "causality": {
      "type": "object"
    },
    "integrity": {
      "type": "object"
    }
  }
}