{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability",
  "type": "object",
  "required": [
    "id",
    "description",
    "riskTier",
    "requiresSandbox",
    "requiresApproval",
    "sideEffects",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "riskTier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "requiresSandbox": {
      "type": "boolean"
    },
    "requiresApproval": {
      "type": "boolean"
    },
    "sideEffects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}