{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SopPack",
  "type": "object",
  "required": [
    "id",
    "version",
    "schemaVersion",
    "name",
    "description",
    "inputs",
    "steps",
    "outputs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "inputs": {
      "type": "object"
    },
    "steps": {
      "type": "array"
    },
    "outputs": {
      "type": "array"
    }
  }
}