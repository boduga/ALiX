{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskNode",
  "type": "object",
  "required": [
    "id",
    "graphId",
    "title",
    "goal",
    "domain",
    "status",
    "dependencies",
    "requiredCapabilities",
    "riskLevel",
    "approvalMode",
    "inputs",
    "artifacts",
    "memoryRefs",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "graphId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "ready",
        "running",
        "blocked",
        "awaiting_approval",
        "cancelling",
        "done",
        "failed",
        "cancelled",
        "skipped"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assignedAgent": {
      "type": "string"
    },
    "requiredCapabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenCapabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "approvalMode": {
      "enum": [
        "auto",
        "ask",
        "deny"
      ]
    },
    "inputs": {
      "type": "object"
    },
    "outputs": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memoryRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    }
  }
}